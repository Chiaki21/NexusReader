@page "/admin/dashboard"
@using NexusReader.Models
@using NexusReader.Services
@inject NavigationManager NavManager
@inject BookService BookService

<div class="admin-container">
    <header class="admin-header">
        <div class="header-content">
            <div>
                <h1 class="title">Library Management</h1>
                <p class="subtitle">Add, edit, or remove books from the catalog</p>
            </div>

            @* --- NEW SEARCH BAR --- *@
            <div class="search-wrapper">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <input type="text" 
                       placeholder="Search by title, author, or category..." 
                       @bind="SearchTerm" 
                       @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(SearchTerm))
                {
                    <button class="btn-clear-search" @onclick='() => SearchTerm = ""'>&times;</button>
                }
            </div>
        </div>

        <button class="btn-primary" @onclick="OpenAddBookModal">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 4v16m8-8H4"/>
            </svg>
            Add New Book
        </button>
    </header>

    <div class="admin-stats">
        <div class="stat-item">
            <span class="label">Total Books</span>
            <span class="value">@BookService.AllBooks.Count</span>
        </div>
        <div class="stat-item">
            <span class="label">Categories</span>
            <span class="value">@BookService.AllBooks.Select(b => b.Category).Distinct().Count()</span>
        </div>
        <div class="stat-item">
            <span class="label">Active Projects</span>
            <span class="value">@BookService.AllBooks.Count(b => b.Progress > 0)</span>
        </div>
    </div>

    <div class="table-container">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Cover</th>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Category</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @* --- SWITCHED TO FILTEREDBOOKS --- *@
                @foreach (var book in FilteredBooks)
                {
                    <tr>
                        <td data-label="Cover">
                            <div class="mini-cover-preview @book.ColorTheme">
                                @if (!string.IsNullOrEmpty(book.CoverImage))
                                {
                                    <img src="@book.CoverImage" alt="Cover" />
                                }
                            </div>
                        </td>
                        <td data-label="Title"><strong>@book.Title</strong></td>
                        <td data-label="Author">@book.Author</td>
                        <td data-label="Category">
                            <span class="category-tag">@book.Category</span>
                        </td>
                        <td data-label="Status">
                            <span class="status-badge @(book.Progress >= 100 ? "completed" : "draft")">
                                @(book.Progress >= 100 ? "Completed" : "Draft")
                            </span>
                        </td>
                        <td data-label="Actions">
                            <div class="action-group">
                                <button class="btn-action edit" @onclick="() => OpenEditBookModal(book)">
                                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    <span>Edit</span>
                                </button>
                                <button class="btn-action write" @onclick='() => NavManager.NavigateTo($"admin/editor/{book.Id}")'>
                                    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 19l9 2-2-9-7 8zM9 3L4 5l2 7h5l3-7z"/></svg>
                                    <span>Write</span>
                                </button>
                                <button class="btn-action delete" @onclick="() => ConfirmDelete(book)">
    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
    </svg>
</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        @if (!FilteredBooks.Any())
        {
            <div class="no-results">
                <p>No books found matching "@SearchTerm"</p>
            </div>
        }
    </div>
</div>

@if (ShowModal)
{
    <div class="modal-overlay">
        <div class="modal-card">
            <header class="modal-header">
                 <h3>@(IsEditing ? "Edit Book" : "Add New Book")</h3>
                 <button class="btn-close" @onclick="CloseModal">×</button>
            </header>

            <div class="modal-body">
                <div class="input-group">
                    <label>Book Title</label>
                    <input type="text" placeholder="e.g. The Midnight Library" @bind="NewBook.Title" />
                </div>

                <div class="input-group">
                    <label>Author</label>
                    <input type="text" placeholder="e.g. Matt Haig" @bind="NewBook.Author" />
                </div>

                <div class="input-group">
    <label>Book Cover Image</label>
    <div class="file-upload-container">
        @* The actual image preview *@
        <div class="book-preview-box @NewBook.ColorTheme">
            @if (!string.IsNullOrEmpty(NewBook.CoverImage))
            {
                <img src="@NewBook.CoverImage" class="upload-preview-img" />
            }
            else
            {
                <div class="placeholder-icon">
                    <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                </div>
            }
        </div>

        @* The upload button/input *@
        <div class="file-upload-controls">
            <label class="btn-secondary upload-label">
                <InputFile OnChange="HandleFileSelected" class="hidden-input" />
                <span>@(string.IsNullOrEmpty(NewBook.CoverImage) ? "Choose Image" : "Change Image")</span>
            </label>
            <p class="upload-hint">Recommended: 300x450px (PNG/JPG)</p>
        </div>
    </div>
</div>

                <div class="input-row">
                    <div class="input-group">
                        <label>Category</label>
                        <select @bind="NewBook.Category">
                            <option value="Romance">Romance</option>
                            <option value="Thriller">Thriller</option>
                            <option value="Sci-Fi">Sci-Fi</option>
                            <option value="Fantasy">Fantasy</option>
                            <option value="Non-Fiction">Non-Fiction</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label>Cover Theme</label>
                        <select @bind="NewBook.ColorTheme">
                            <option value="blush">Blush (Pink/Red)</option>
                            <option value="slate">Slate (Dark Gray)</option>
                            <option value="emerald">Emerald (Green)</option>
                            <option value="peach">Peach (Orange)</option>
                            <option value="lavender">Lavender (Purple)</option>
                        </select>
                    </div>
                </div>
            </div>

           <footer class="modal-footer">
    @if (IsEditing)
    {
        <button class="btn-action write" style="margin-right: auto;" 
                @onclick='() => NavManager.NavigateTo($"admin/editor/{NewBook.Id}")'>
            🖋️ Write Content
        </button>
    }
    <button class="btn-secondary" @onclick="CloseModal">Cancel</button>
    <button class="btn-primary" @onclick="SaveBook">Save Changes</button>
</footer>
        </div>
    </div>
}

@if (ShowDeleteModal)
{
    <div class="modal-overlay">
        <div class="confirm-modal">
            <div class="modal-icon danger">
                <svg width="40" height="40" fill="none" stroke="#ef4444" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
            </div>
            <h3>Delete Book?</h3>
            <p>Are you sure you want to delete <strong>"@BookToDelete?.Title"</strong>? This action cannot be undone.</p>
            
            <div class="modal-actions">
                <button class="btn-secondary" @onclick="CancelDelete">Cancel</button>
                <button class="btn-danger" @onclick="ExecuteDelete">Delete Permanently</button>
            </div>
        </div>
    </div>
}

@code {
    private bool ShowModal = false;
    private bool ShowDeleteModal = false; // NEW
    private bool IsEditing = false;
    private BookModel NewBook = new();
    private BookModel? BookToDelete; // NEW
    private string SearchTerm { get; set; } = "";

    private IEnumerable<BookModel> FilteredBooks => 
        string.IsNullOrWhiteSpace(SearchTerm) 
            ? BookService.AllBooks 
            : BookService.AllBooks.Where(b => 
                b.Title.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) || 
                b.Author.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
                b.Category.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase));

    private void OpenAddBookModal() 
    {
        IsEditing = false;
        NewBook = new BookModel { Category = "Romance", ColorTheme = "blush" }; 
        ShowModal = true;
    }

    private void OpenEditBookModal(BookModel book)
    {
        IsEditing = true;
        NewBook = new BookModel 
        { 
            Id = book.Id,
            Title = book.Title, 
            Author = book.Author, 
            Category = book.Category, 
            ColorTheme = book.ColorTheme, 
            CoverImage = book.CoverImage,
            Description = book.Description,
            Progress = book.Progress
        };
        ShowModal = true;
    }

    private void CloseModal() => ShowModal = false;

    // --- NEW DELETE MODAL LOGIC ---
    private void ConfirmDelete(BookModel book)
    {
        BookToDelete = book;
        ShowDeleteModal = true;
    }

    private void CancelDelete()
    {
        BookToDelete = null;
        ShowDeleteModal = false;
    }

    private void ExecuteDelete()
    {
        if (BookToDelete != null)
        {
            var book = BookService.AllBooks.FirstOrDefault(b => b.Id == BookToDelete.Id);
            if (book != null)
            {
                BookService.AllBooks.Remove(book);
            }
            CancelDelete(); // Resets variables and closes modal
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            var format = "image/png";
            var resizedImage = await file.RequestImageFileAsync(format, 300, 450);
            var buffer = new byte[resizedImage.Size];
            
            using var stream = resizedImage.OpenReadStream();
            await stream.ReadAsync(buffer, 0, (int)resizedImage.Size); 
            
            NewBook.CoverImage = $"data:{format};base64,{Convert.ToBase64String(buffer)}";
        }
    }

    private void SaveBook()
    {
        if (IsEditing)
        {
            var index = BookService.AllBooks.FindIndex(b => b.Id == NewBook.Id);
            if (index != -1)
            {
                BookService.AllBooks[index] = NewBook;
            }
        }
        else
        {
            NewBook.Id = BookService.AllBooks.Any() ? BookService.AllBooks.Max(b => b.Id) + 1 : 1;
            BookService.AllBooks.Insert(0, NewBook);
        }

        ShowModal = false;
    }
}