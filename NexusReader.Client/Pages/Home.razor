@page "/"

@inject NavigationManager NavManager
@inject BookService BookService

<div class="dashboard-container">
    
    <header class="dashboard-header">
        <h1 class="page-title">Welcome back!</h1>
        <p class="page-subtitle">Pick up where you left off or start something new.</p>
    </header>

   <section class="continue-reading-section">
        <h2 class="section-title">Continue Reading</h2>
        @* Added click event to the hero card (Assuming ID 1 is the main book) *@
        <div class="hero-card" @onclick='() => NavManager.NavigateTo("book/1")' style="cursor: pointer;">
            <div class="hero-cover" style="background: linear-gradient(135deg, #e11d48, #9f1239);">
                <span class="cover-text">It Ends with Us</span>
            </div>
            <div class="hero-info">
                <h3 class="hero-title">It Ends with Us</h3>
                <p class="hero-author">Colleen Hoover</p>
                
                <div class="progress-container">
                    <div class="progress-bar" style="width: 82%;"></div>
                </div>
                <p class="progress-text">82% completed • Chapter 24</p>
                
                <button class="btn-primary" @onclick:stopPropagation="true" @onclick='() => NavManager.NavigateTo("reader/1")'>
    Resume Reading
</button>
            </div>
        </div>
    </section>

    <section class="library-section">
        <div class="library-header">
            <h2 class="section-title">Your Library</h2>
            @* We'll link this to the search or a placeholder for now *@
            <button class="btn-secondary" @onclick='() => NavManager.NavigateTo("search")'>+ Add Book</button>
        </div>

        <div class="book-grid">
            @foreach (var book in DummyBooks)
            {
                @* Clicking the card navigates to the Details page using the book's Id *@
                <div class="book-card" @onclick='() => NavManager.NavigateTo($"book/{book.Id}")' style="cursor: pointer;">
                    <div class="book-cover placeholder-@book.ColorTheme">
                        <span class="cover-text">@book.Title</span>
                    </div>
                    <div class="book-details">
                        <h4 class="book-title">@book.Title</h4>
                        <p class="book-author">@book.Author</p>
                        
                        @if (book.Progress > 0 && book.Progress < 100)
                        {
                            <div class="mini-progress-container">
                                <div class="mini-progress-bar" style="width: @(book.Progress)%"></div>
                            </div>
                        }
                        else if (book.Progress == 100)
                        {
                            <span class="badge-finished">Finished</span>
                        }
                    </div>
                </div>
            }
        </div>
    </section>

</div>

@code {
    private List<BookModel> DummyBooks => BookService.AllBooks;
}