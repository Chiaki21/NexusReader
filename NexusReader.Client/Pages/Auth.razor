@page "/auth"
@using NexusReader.Services
@using NexusReader.Shared.Models
@inject NavigationManager NavManager
@inject AuthStateService AuthState

<div class="auth-wrapper">
    <div class="auth-visual">
        <div class="visual-content">
            <svg class="visual-graphic" viewBox="0 0 400 300" fill="none">
                <path d="M200,50 Q250,100 200,150 Q150,200 200,250" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M180,70 L220,130 M220,70 L180,130" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <h1 class="visual-title">Find Your Next Great Escape</h1>
            <p class="visual-subtitle">Welcome to NexusReader, the ultimate sanctuary for your collection.</p>
        </div>
    </div>

    <div class="auth-form-container">
        <div class="auth-card">
            <header class="auth-header">
                <div class="logo-box">
                    <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
                    </svg>
                </div>
                <h1 class="auth-title">@(IsLoginMode ? "Sign in to NexusReader" : "Create your account")</h1>
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <p class="error-text" style="color: #ff4d4d; font-size: 0.85rem; margin-top: 10px;">@errorMessage</p>
                }
            </header>

            <EditForm Model="this" OnValidSubmit="HandleAuth" class="auth-form">
                @if (!IsLoginMode)
                {
                    <div class="input-row">
                        <div class="input-group">
                            <label>First Name</label>
                            <input type="text" placeholder="Jane" @bind="firstName" />
                        </div>
                        <div class="input-group">
                            <label>Last Name</label>
                            <input type="text" placeholder="Doe" @bind="lastName" />
                        </div>
                    </div>
                }

                <div class="input-group">
                    <label>Email Address</label>
                    <input type="email" placeholder="name@example.com" @bind="email" required />
                </div>

                <div class="input-group">
                    <label>Password</label>
                    <input type="password" placeholder="••••••••" @bind="password" required />
                </div>

                @if (!IsLoginMode)
                {
                    <div class="input-group">
                        <label>Confirm Password</label>
                        <input type="password" placeholder="••••••••" @bind="confirmPassword" required />
                    </div>

                    <div class="age-verification">
                        <label>Are you over 18 years old?</label>
                        <div class="radio-group">
                            <label class="radio-option">
                                <input type="radio" name="age" value="yes" required />
                                <span>Yes</span>
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="age" value="no" />
                                <span>No</span>
                            </label>
                        </div>
                    </div>
                }
                
                @if (IsLoginMode)
                {
                    <button type="button" class="btn-link forgot-password">Forgot Password?</button>
                }

                <button type="submit" class="btn-primary auth-submit" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span>Processing...</span>
                    }
                    else
                    {
                        @(IsLoginMode ? "Sign In" : "Sign Up")
                    }
                </button>
            </EditForm>

            <div class="auth-footer">
                <button class="btn-secondary" @onclick="ToggleMode">
                    @(IsLoginMode ? "Don't have an account? Sign Up" : "Already have an account? Sign In")
                </button>
                
                <hr class="divider" />
                
                <button type="button" class="btn-admin-shortcut" @onclick="LoginAsAdmin">
                    Login as Admin (Dev Shortcut)
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private bool IsLoginMode = true;
    private bool isSubmitting = false;
    private string errorMessage = "";

    // Form Fields
    private string email = "";
    private string password = "";
    private string confirmPassword = "";
    private string firstName = "";
    private string lastName = "";

    private async Task HandleAuth()
    {
        errorMessage = "";
        isSubmitting = true;

        if (IsLoginMode)
        {
            var success = await AuthState.Login(email, password);
            if (success) NavManager.NavigateTo("");
            else errorMessage = "Invalid email or password.";
        }
        else
        {
            if (password != confirmPassword)
            {
                errorMessage = "Passwords do not match.";
                isSubmitting = false;
                return;
            }

            var success = await AuthState.Register(email, password, confirmPassword);
            if (success) 
            {
                IsLoginMode = true; // Switch to login after successful register
                errorMessage = "Registration successful! Please sign in.";
            }
            else 
            {
                errorMessage = "Registration failed. Check password requirements.";
            }
        }

        isSubmitting = false;
    }

    private void ToggleMode()
    {
        IsLoginMode = !IsLoginMode;
        errorMessage = "";
    }

    private void LoginAsAdmin()
    {
        AuthState.SetAdmin(true);
        NavManager.NavigateTo("admin/dashboard");
    }
}