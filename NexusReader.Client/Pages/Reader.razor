@page "/reader/{BookId:int}/{ChapterId:int}"
@using NexusReader.Services
@using NexusReader.Shared.Models
@inject NavigationManager NavManager
@inject UserSettingsService Settings
@inject BookService BookService
@implements IDisposable
@inject IJSRuntime JS

@if (Content != null)
{
    <div class="reader-container @(ShowMenu ? "menu-visible" : "menu-hidden")" @onclick="ToggleMenu">
        <nav class="reader-nav" @onclick:stopPropagation>
            <button type="button" class="back-button" @onclick="GoBack">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M15 18l-6-6 6-6" />
                </svg>
                <span>Back</span>
            </button>
            <div class="book-metadata">
                <span class="chapter-label">Chapter @Content.ChapterNumber</span>
                <h2 class="book-title-small">@Content.BookTitle</h2>
            </div>
            <button type="button" class="settings-trigger" @onclick='() => NavManager.NavigateTo("settings")'>
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M4 6h16M4 12h16m-7 6h7" />
                </svg>
            </button>
        </nav>

        <main class="reading-surface">
            <article class="prose reader-article" style="font-size: @(Settings.FontSize)px;">
                <h1 class="reader-chapter-title">@Content.Title</h1>
                <div class="reader-body">
                    @((MarkupString)SanitizedContent)
                </div>
            </article>
        </main>

        <div class="reader-footer" @onclick:stopPropagation>
            <button type="button" class="nav-btn" disabled="@(Content.PrevChapterId == null)" @onclick="GoPrev">Previous</button>
            <div class="reading-progress">
                <span>@Content.ChapterNumber / @TotalChapters</span>
            </div>
            <button type="button" class="nav-btn" disabled="@(Content.NextChapterId == null)" @onclick="GoNext">Next</button>
        </div>
    </div>
}
else if (LoadError != null)
{
    <p class="reader-error">@LoadError</p>
}
else
{
    <p class="reader-loading">Loading…</p>
}

@code {
    [Parameter] public int BookId { get; set; }
    [Parameter] public int ChapterId { get; set; }

    private ChapterContentResponse? Content;
    private int TotalChapters = 1;
    private bool ShowMenu = true;
    private string? LoadError;

    private string SanitizedContent =>
        string.IsNullOrEmpty(Content?.Content)
            ? "<p></p>"
            : Content!.Content;

    private void ToggleMenu() => ShowMenu = !ShowMenu;

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");

    protected override async Task OnParametersSetAsync()
    {
        await LoadChapter();
    }

    private async Task LoadChapter()
    {
        LoadError = null;
        Content = await BookService.GetChapterContentAsync(ChapterId);
        if (Content == null)
        {
            LoadError = "Could not load chapter.";
            return;
        }

        var toc = await BookService.GetChapterListAsync(BookId);
        TotalChapters = Math.Max(1, toc.Count);
    }

    private void GoPrev()
    {
        if (Content?.PrevChapterId != null)
            NavManager.NavigateTo($"/reader/{BookId}/{Content.PrevChapterId}");
    }

    private void GoNext()
    {
        if (Content?.NextChapterId != null)
            NavManager.NavigateTo($"/reader/{BookId}/{Content.NextChapterId}");
    }

    protected override void OnInitialized()
    {
        Settings.OnChange += StateHasChanged;
    }

    public void Dispose() => Settings.OnChange -= StateHasChanged;
}
