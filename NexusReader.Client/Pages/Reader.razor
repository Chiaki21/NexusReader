@page "/reader/{BookId:int}"
@inject NavigationManager NavManager
@inject UserSettingsService Settings
@inject BookService BookService
@implements IDisposable
@inject IJSRuntime JS

@if (CurrentBook != null)
{
    <div class="reader-container @(ShowMenu ? "menu-visible" : "menu-hidden")" @onclick="ToggleMenu">
        
        <nav class="reader-nav" @onclick:stopPropagation>
            <button class="back-button" @onclick="GoBack">
                <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M15 18l-6-6 6-6" />
                </svg>
                <span>Back</span>
            </button>
            <div class="book-metadata">
                <span class="chapter-label">Chapter 1</span>
                <h2 class="book-title-small">@CurrentBook.Title</h2>
            </div>
            <button class="settings-trigger" @onclick='() => NavManager.NavigateTo("settings")'>
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M4 6h16M4 12h16m-7 6h7" />
                </svg>
            </button>
        </nav>

        <main class="reading-surface">
            <article class="prose" style="font-size: @(Settings.FontSize)px;">
                <h1>Chapter One</h1>
                <p>The problem with being a person who loves stories is that you’re always looking for the beauty in things that are meant to be temporary.</p>
                <p>I looked at the pages, and for a second, the rest of the world just went quiet. It wasn’t a loud realization. It was soft, like the petals of a lily opening at dawn.</p>
                <p>"You’re thinking again," the voice said, a low vibration that seemed to settle right in my chest.</p>
                <p>This was the start of something new. A journey through @CurrentBook.Category that would change everything.</p>
            </article>
        </main>

        <div class="reader-footer" @onclick:stopPropagation>
            <button class="nav-btn">Previous</button>
            <div class="reading-progress">
                <div class="progress-dot"></div>
                <span>Page 1 of 350</span>
            </div>
            <button class="nav-btn">Next</button>
        </div>
    </div>
}

@code {
    [Parameter] public int BookId { get; set; }
    private BookModel? CurrentBook;
    private bool ShowMenu = true; // Default to showing menu so user can see context

    private async Task GoBack() => await JS.InvokeVoidAsync("history.back");
    private void ToggleMenu() => ShowMenu = !ShowMenu;

    protected override void OnInitialized()
    {
        CurrentBook = BookService.GetBookById(BookId);
        
        if (CurrentBook == null)
            NavManager.NavigateTo("");

        Settings.OnChange += StateHasChanged;
    }

    public void Dispose() => Settings.OnChange -= StateHasChanged;
}