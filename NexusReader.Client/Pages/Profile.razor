@page "/profile"
@using NexusReader.Services
@inject NavigationManager NavManager
@inject AuthStateService AuthService
@inject UserSettingsService Settings

<div class="profile-container">
    <header class="profile-header">
        <div class="avatar-circle">
            <span>JD</span>
        </div>
        <h1 class="user-name">Jane Doe</h1>
        <p class="user-handle">@@romance_reader_26</p>
        <div class="header-actions">
            <button class="btn-edit">Edit Profile</button>
        </div>
    </header>

    <div class="stats-grid">
        <div class="stat-card">
            <span class="stat-value">12</span>
            <span class="stat-label">Books Read</span>
        </div>
        <div class="stat-card">
            <span class="stat-value">5</span>
            <span class="stat-label">This Month</span>
        </div>
        <div class="stat-card">
            <span class="stat-value">14</span>
            <span class="stat-label">Day Streak</span>
        </div>
    </div>

    @* Settings & Actions Section *@
    <section class="settings-section">
        <h2 class="section-title">Account Settings</h2>
        <div class="settings-list">
            <div class="settings-item" @onclick="async () => await Settings.ToggleDarkMode()">
                <div class="settings-info">
                    <span class="settings-name">Appearance</span>
                    <span class="settings-desc">Switch between light and dark mode</span>
                </div>
                <div class="toggle-status">
                    @(Settings.IsDarkMode ? "Dark" : "Light")
                </div>
            </div>

            <div class="settings-item">
                <div class="settings-info">
                    <span class="settings-name">Notifications</span>
                    <span class="settings-desc">Manage reading reminders</span>
                </div>
                <svg class="chevron-icon" width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
            </div>

            <button class="settings-item logout-item" @onclick="HandleSignOut">
                <div class="settings-info">
                    <span class="settings-name">Sign Out</span>
                    <span class="settings-desc">Securely exit your account</span>
                </div>
                <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            </button>
        </div>
    </section>

    <section class="goal-section">
        <div class="goal-header">
            <h2 class="section-title">2026 Reading Goal</h2>
            <span class="goal-count">12 / 50 books</span>
        </div>
        <div class="goal-progress-bg">
            <div class="goal-progress-fill" style="width: 24%;"></div>
        </div>
    </section>

    @* Recently Finished remains the same... *@
</div>

@code {
    private void HandleSignOut()
    {
        AuthService.Logout();
        NavManager.NavigateTo("auth");
    }
}