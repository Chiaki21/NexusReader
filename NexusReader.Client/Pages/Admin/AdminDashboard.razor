@page "/admin/dashboard"
@using NexusReader.Shared.Models
@using NexusReader.Services
@inject NavigationManager NavManager
@inject BookService BookService

<div class="admin-container">
    <header class="admin-header">
        <div class="header-content">
            <div>
                <h1 class="title">Library Management</h1>
                <p class="subtitle">Add, edit, or remove books from the catalog</p>
            </div>

            <div class="search-wrapper">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                </svg>
                <input type="text"
                       placeholder="Search by title, author, or category..."
                       @bind="SearchTerm"
                       @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(SearchTerm))
                {
                    <button type="button" class="btn-clear-search" @onclick='() => SearchTerm = ""'>&times;</button>
                }
            </div>
        </div>

        <button type="button" class="btn-primary" @onclick="OpenAddBookModal">
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 4v16m8-8H4"/>
            </svg>
            Add New Book
        </button>
    </header>

    <div class="admin-stats">
        <div class="stat-item">
            <span class="label">Total Books</span>
            <span class="value">@Books.Count</span>
        </div>
        <div class="stat-item">
            <span class="label">Categories</span>
            <span class="value">@Books.Select(b => b.Category).Distinct().Count()</span>
        </div>
        <div class="stat-item">
            <span class="label">In Progress</span>
            <span class="value">@Books.Count(b => b is { Progress: > 0 and < 100 })</span>
        </div>
    </div>

    <div class="table-container">
        @if (Loading)
        {
            <p>Loading catalog…</p>
        }
        else
        {
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Cover</th>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var book in FilteredBooks)
                    {
                        <tr>
                            <td data-label="Cover">
                                <div class="mini-cover-preview @book.ColorTheme">
                                    @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                                    {
                                        <img src="@book.CoverImageUrl" alt="" />
                                    }
                                </div>
                            </td>
                            <td data-label="Title"><strong>@book.Title</strong></td>
                            <td data-label="Author">@book.Author</td>
                            <td data-label="Category">
                                <span class="category-tag">@book.Category</span>
                            </td>
                            <td data-label="Status">
                                <span class="status-badge @(book.Progress >= 100 ? "completed" : "draft")">
                                    @(book.Progress >= 100 ? "Completed" : "Draft")
                                </span>
                            </td>
                            <td data-label="Actions">
                                <div class="action-group">
                                    <button type="button" class="btn-action edit" @onclick="async () => await OpenEditBookModal(book)">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                        <span>Edit</span>
                                    </button>
                                    <button type="button" class="btn-action write" @onclick='() => NavManager.NavigateTo($"admin/editor/{book.Id}")'>
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 19l9 2-2-9-7 8zM9 3L4 5l2 7h5l3-7z"/></svg>
                                        <span>Write</span>
                                    </button>
                                    <button type="button" class="btn-action delete" @onclick="() => ConfirmDelete(book)">
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (!FilteredBooks.Any())
            {
                <div class="no-results">
                    <p>No books found matching "@SearchTerm"</p>
                </div>
            }
        }
    </div>
</div>

@if (ShowModal)
{
    <div class="modal-overlay">
        <div class="modal-card">
            <header class="modal-header">
                <h3>@(IsEditing ? "Edit Book" : "Add New Book")</h3>
                <button type="button" class="btn-close" @onclick="CloseModal">×</button>
            </header>

            <div class="modal-body">
                <div class="input-group">
                    <label>Book Title</label>
                    <input type="text" placeholder="e.g. The Midnight Library" @bind="NewBook.Title" />
                </div>

                <div class="input-group">
                    <label>Author</label>
                    <input type="text" placeholder="e.g. Matt Haig" @bind="NewBook.Author" />
                </div>

                <div class="input-group">
                    <label>Description</label>
                    <textarea rows="4" placeholder="Synopsis…" @bind="NewBook.Description"></textarea>
                </div>

                <div class="input-group">
                    <label>Book Cover Image</label>
                    <div class="file-upload-container">
                        <div class="book-preview-box @NewBook.ColorTheme">
                            @if (!string.IsNullOrEmpty(NewBook.CoverImageUrl))
                            {
                                <img src="@NewBook.CoverImageUrl" class="upload-preview-img" alt="" />
                            }
                            else
                            {
                                <div class="placeholder-icon">
                                    <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                                        <path d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                    </svg>
                                </div>
                            }
                        </div>

                        <div class="file-upload-controls">
                            <label class="btn-secondary upload-label">
                                <InputFile OnChange="HandleFileSelected" class="hidden-input" />
                                <span>@(string.IsNullOrEmpty(NewBook.CoverImageUrl) ? "Choose Image" : "Change Image")</span>
                            </label>
                            <p class="upload-hint">Recommended: 300×450px (PNG/JPG). Stored as data URL.</p>
                        </div>
                    </div>
                </div>

                <div class="input-row">
                    <div class="input-group">
                        <label>Category</label>
                        <select @bind="NewBook.Category">
                            <option value="Romance">Romance</option>
                            <option value="Thriller">Thriller</option>
                            <option value="Sci-Fi">Sci-Fi</option>
                            <option value="Fantasy">Fantasy</option>
                            <option value="Non-Fiction">Non-Fiction</option>
                        </select>
                    </div>
                    <div class="input-group">
                        <label>Cover Theme</label>
                        <select @bind="NewBook.ColorTheme">
                            <option value="blush">Blush</option>
                            <option value="slate">Slate</option>
                            <option value="emerald">Emerald</option>
                            <option value="peach">Peach</option>
                            <option value="lavender">Lavender</option>
                        </select>
                    </div>
                </div>
            </div>

            <footer class="modal-footer">
                @if (IsEditing)
                {
                    <button type="button" class="btn-action write" style="margin-right: auto;"
                            @onclick='() => NavManager.NavigateTo($"admin/editor/{NewBook.Id}")'>
                        Write Content
                    </button>
                }
                <button type="button" class="btn-secondary" @onclick="CloseModal">Cancel</button>
                <button type="button" class="btn-primary" @onclick="SaveBookAsync">Save</button>
            </footer>
        </div>
    </div>
}

@if (ShowDeleteModal)
{
    <div class="modal-overlay">
        <div class="confirm-modal">
            <div class="modal-icon danger">
                <svg width="40" height="40" fill="none" stroke="#ef4444" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
            </div>
            <h3>Delete Book?</h3>
            <p>Are you sure you want to delete <strong>"@BookToDelete?.Title"</strong>? This action cannot be undone.</p>

            <div class="modal-actions">
                <button type="button" class="btn-secondary" @onclick="CancelDelete">Cancel</button>
                <button type="button" class="btn-danger" @onclick="ExecuteDeleteAsync">Delete Permanently</button>
            </div>
        </div>
    </div>
}

@code {
    private List<BookSummaryResponse> Books { get; set; } = new();
    private bool Loading = true;
    private bool ShowModal;
    private bool ShowDeleteModal;
    private bool IsEditing;
    private BookModel NewBook = new();
    private BookSummaryResponse? BookToDelete;
    private string SearchTerm = "";

    private IEnumerable<BookSummaryResponse> FilteredBooks =>
        string.IsNullOrWhiteSpace(SearchTerm)
            ? Books
            : Books.Where(b =>
                b.Title.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
                b.Author.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase) ||
                b.Category.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync() => await LoadBooksAsync();

    private async Task LoadBooksAsync()
    {
        Loading = true;
        Books = await BookService.GetBooksAsync();
        Loading = false;
    }

    private void OpenAddBookModal()
    {
        IsEditing = false;
        NewBook = new BookModel { Category = "Romance", ColorTheme = "blush", Description = "" };
        ShowModal = true;
    }

    private async Task OpenEditBookModal(BookSummaryResponse book)
    {
        IsEditing = true;
        var full = await BookService.GetBookAsync(book.Id);
        NewBook = full ?? new BookModel
        {
            Id = book.Id,
            Title = book.Title,
            Author = book.Author,
            Category = book.Category,
            ColorTheme = book.ColorTheme,
            CoverImageUrl = book.CoverImageUrl,
            Progress = book.Progress,
            Description = ""
        };
        ShowModal = true;
    }

    private void CloseModal() => ShowModal = false;

    private void ConfirmDelete(BookSummaryResponse book)
    {
        BookToDelete = book;
        ShowDeleteModal = true;
    }

    private void CancelDelete()
    {
        BookToDelete = null;
        ShowDeleteModal = false;
    }

    private async Task ExecuteDeleteAsync()
    {
        if (BookToDelete == null) return;
        await BookService.DeleteBookAsync(BookToDelete.Id);
        await LoadBooksAsync();
        CancelDelete();
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        const string format = "image/png";
        var resizedImage = await file.RequestImageFileAsync(format, 300, 450);
        var buffer = new byte[resizedImage.Size];
        await using var stream = resizedImage.OpenReadStream();
        await stream.ReadAsync(buffer.AsMemory(0, (int)resizedImage.Size));

        NewBook.CoverImageUrl = $"data:{format};base64,{Convert.ToBase64String(buffer)}";
    }

    private async Task SaveBookAsync()
    {
        if (IsEditing)
        {
            await BookService.UpdateBookAsync(NewBook.Id, new UpdateBookRequest(
                NewBook.Title,
                NewBook.Author,
                NewBook.Description,
                NewBook.CoverImageUrl,
                NewBook.Category,
                NewBook.ColorTheme,
                NewBook.Progress));
        }
        else
        {
            await BookService.CreateBookAsync(new CreateBookRequest(
                NewBook.Title,
                NewBook.Author,
                NewBook.Description,
                NewBook.CoverImageUrl,
                NewBook.Category,
                NewBook.ColorTheme));
        }

        await LoadBooksAsync();
        ShowModal = false;
    }
}
