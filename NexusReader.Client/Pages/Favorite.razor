@page "/favorites"
@using NexusReader.Services
@using NexusReader.Shared.Models
@inject NavigationManager NavManager
@inject FavoriteService FavoriteService

<div class="favorites-container">
    <header class="favorites-header">
        <h1 class="title">My Favorites</h1>
        <p class="subtitle">The stories that stayed with you.</p>
    </header>

    @if (Loading)
    {
        <p class="subtitle">Loading…</p>
    }
    else if (Books.Any())
    {
        <div class="book-grid">
            @foreach (var book in Books)
            {
                <div class="book-card" @onclick='() => NavManager.NavigateTo($"book/{book.Id}")' style="cursor: pointer;">
                    <div class="book-cover @(string.IsNullOrEmpty(book.CoverImageUrl) ? $"placeholder-{book.ColorTheme}" : "has-image")"
                         style="@(!string.IsNullOrEmpty(book.CoverImageUrl) ? $"background-image:url({book.CoverImageUrl}); background-size:cover;" : "")">
                        <div class="heart-badge">❤️</div>
                        @if (string.IsNullOrEmpty(book.CoverImageUrl))
                        {
                            <span class="cover-text">@book.Title</span>
                        }
                    </div>
                    <div class="book-details">
                        <h4 class="book-title">@book.Title</h4>
                        <p class="book-author">@book.Author</p>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-favorites">
            <div class="empty-icon">💖</div>
            <h2>No favorites yet</h2>
            <p>Save books from the details page to see them here.</p>
            <button type="button" class="btn-primary" @onclick='() => NavManager.NavigateTo("")'>Explore Library</button>
        </div>
    }
</div>

@code {
    private List<BookSummaryResponse> Books { get; set; } = new();
    private bool Loading = true;

    protected override async Task OnInitializedAsync()
    {
        Books = await FavoriteService.GetFavoritesAsync();
        Loading = false;
    }
}
