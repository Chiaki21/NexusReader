@inherits LayoutComponentBase
@using NexusReader.Services
@inject UserSettingsService Settings
@inject NavigationManager NavManager
@inject AuthStateService Auth
@implements IDisposable

<div class="app-root @(Settings.IsDarkMode ? "dark-theme" : "light-theme")" 
     style="--dynamic-font-size: @(Settings.FontSize)px;">
    
    <div class="page-layout">
        @* The sidebar now hides if we are on Auth OR Reader *@
        @if (!IsFullscreenPage)
        {
            <aside class="sidebar">
                <NavMenu />
            </aside>
        }

        <main class="content-area">
            @* We add 'no-padding' to the wrapper if in fullscreen mode *@
            <article class="content-wrapper @(IsFullscreenPage ? "no-padding" : "")">
                @Body
            </article>
        </main>
    </div>
</div>

@code {
    // Helper to check the current URL
    private bool IsFullscreenPage => 
        NavManager.Uri.EndsWith("/auth") || 
        NavManager.Uri.Contains("/reader");

    protected override async Task OnInitializedAsync()
    {
        await Auth.RestoreSessionAsync();
        EnforceRouteAccess();

        await Settings.InitializeAsync();

        Settings.OnChange += StateHasChanged;
        NavManager.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        EnforceRouteAccess();
        StateHasChanged();
    }

    private void EnforceRouteAccess()
    {
        var path = new Uri(NavManager.Uri).AbsolutePath;
        if (path.Length > 1 && path.EndsWith('/'))
            path = path.TrimEnd('/');

        var isAuthPage = path.Equals("/auth", StringComparison.OrdinalIgnoreCase);

        if (isAuthPage && Auth.IsLoggedIn)
        {
            NavManager.NavigateTo("/", replace: true);
            return;
        }

        if (!isAuthPage && !Auth.IsLoggedIn)
        {
            NavManager.NavigateTo("/auth", replace: true);
            return;
        }

        var isAdminPath = path.StartsWith("/admin", StringComparison.OrdinalIgnoreCase);
        if (isAdminPath && Auth.IsLoggedIn && !Auth.IsAdmin)
            NavManager.NavigateTo("/", replace: true);
    }

    public void Dispose()
    {
        Settings.OnChange -= StateHasChanged;
        NavManager.LocationChanged -= HandleLocationChanged;
    }

}