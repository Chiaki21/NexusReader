@inject UserSettingsService Settings
@inject NavigationManager NavManager
@using NexusReader.Services
@inject AuthStateService AuthService
@implements IDisposable

<div class="lovable-sidebar">
    <div class="brand-header desktop-only">
        <div class="logo-box">
            <svg class="logo-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
            </svg>
        </div>
        <span class="brand-text">NexusReader</span>
    </div>

   <nav class="menu-list">
    <button class="action-item" @onclick='() => NavManager.NavigateTo("")'>
        <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
        </svg>
        <span class="menu-label">Library</span>
    </button>

    <button class="action-item" @onclick='() => NavManager.NavigateTo("search")'>
        <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
        <span class="menu-label">Search</span>
    </button>

    <button class="action-item" @onclick='() => NavManager.NavigateTo("favorites")'>
        <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
        </svg>
        <span class="menu-label">Favorites</span>
    </button>

    @if (AuthService.IsAdmin)
    {
        @* Divider only shows on Desktop *@
        <div class="nav-divider desktop-only">Management</div>
        
        <button class="action-item admin-highlight" @onclick='() => NavManager.NavigateTo("admin/dashboard")'>
            <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
            <span class="menu-label">Admin</span>
        </button>
    }

    @* Profile is now consistently the last item *@
    <button class="action-item" @onclick='() => NavManager.NavigateTo("profile")'>
        <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
        </svg>
        <span class="menu-label">Profile</span>
    </button>
</nav>

    <div class="sidebar-footer desktop-only">
        <button class="action-item" @onclick="async () => await Settings.ToggleDarkMode()">
            @if (Settings.IsDarkMode)
            {
                 <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
                <span class="menu-label">Light mode</span>
            }
            else
            {
                <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
                </svg>
                <span class="menu-label">Dark mode</span>
            }
        </button>

        <button class="action-item" @onclick="HandleSignOut">
            <svg class="menu-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/>
            </svg>
            <span class="menu-label">Sign out</span>
        </button>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        Settings.OnChange += StateHasChanged;
        AuthService.OnAuthStateChanged += StateHasChanged;
    }

    private void HandleSignOut()
    {
        AuthService.Logout();
        NavManager.NavigateTo("auth");
    }

    public void Dispose()
    {
        Settings.OnChange -= StateHasChanged;
        AuthService.OnAuthStateChanged -= StateHasChanged;
    }
}